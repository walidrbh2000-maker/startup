# ── API ────────────────────────────────────────────────────────────────────
# Leave empty to use the Vite dev proxy (/api → http://localhost:3000).
# In production set to the deployed API origin, e.g. https://api.khidmeti.com
VITE_API_BASE_URL=/api

# Dev-only: where the /api proxy forwards to (see vite.config.ts).
VITE_DEV_API_TARGET=http://localhost:3000

# ── Firebase (same project as the mobile app / backend) ─────────────────────
# From Firebase console → Project settings → Web app config.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_APP_ID=

# ── App store links (used by the marketing download CTA) ────────────────────
# Android applicationId is com.khidmeti (khid-app/android/app/build.gradle.kts).
# The Play link goes live once the app is published; replace the iOS URL with
# the real App Store link when an iOS build ships.
VITE_APP_ANDROID_URL=https://play.google.com/store/apps/details?id=com.khidmeti
VITE_APP_IOS_URL=#
